# Copie ce fichier dans ~/.new-site.env (jamais commité !)
# cp scripts/new-site.env.example ~/.new-site.env

# GitHub — token avec scopes : repo, workflow, admin:repo_hook
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Ton username GitHub
GITHUB_USERNAME=lolosequence

# Nom du repo template (défaut: Ma-website-factory)
GITHUB_TEMPLATE=Ma-website-factory

# Vercel — Account Settings → Tokens
# https://vercel.com/account/tokens
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Vercel Team ID (laisser vide si compte personnel)
# Visible dans vercel.com/teams/xxx/settings
VERCEL_TEAM_ID=

# Neon — Account → API Keys
# https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=xxxxxxxxxxxxxxxxxxxx

# Région Neon (défaut: aws-eu-central-1)
NEON_REGION=aws-eu-central-1

# Chemin local pour cloner les nouveaux repos
LOCAL_PROJECTS_DIR=/mnt/c/Users/laure/Mes projets
