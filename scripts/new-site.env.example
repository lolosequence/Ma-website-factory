# Copie ce fichier dans ~/.new-site.env (jamais commité !)
# cp scripts/new-site.env.example ~/.new-site.env

# GitHub — token avec scopes : repo, workflow, admin:repo_hook
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Ton username GitHub
GITHUB_USERNAME=lolosequence

# Nom du repo template (défaut: Ma-website-factory)
GITHUB_TEMPLATE=Ma-website-factory

# Chemin local pour cloner les nouveaux repos
LOCAL_PROJECTS_DIR=/mnt/c/Users/laure/Mes projets/Mes clients

# ─── Dokploy ───────────────────────────────────────────────────────────────────
# URL de ton instance Dokploy admin (sans slash final)
DOKPLOY_URL=https://admin.workflowlolo.fr

# Token API Dokploy → Settings → Profile → Generate API Token
DOKPLOY_TOKEN=xxxxxxxxxxxxxxxxxxxx
