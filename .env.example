# ─── Base de données PostgreSQL ───────────────────────────────────────────────
# Format : postgresql://<user>:<password>@<host>:<port>/<database>
# Dev local (docker-compose) : postgresql://payload:payload@localhost:5432/payload
# Production Dokploy          : utiliser l'hôte interne du service Postgres
DATABASE_URL=postgresql://payload:payload@localhost:5432/payload

# Variables docker-compose (optionnel, valeurs par défaut ci-dessus)
POSTGRES_USER=payload
POSTGRES_PASSWORD=payload
POSTGRES_DB=payload
POSTGRES_PORT=5432

# ─── Payload CMS ──────────────────────────────────────────────────────────────
# Clé secrète — générer avec : openssl rand -hex 32
PAYLOAD_SECRET=

# ─── Application ──────────────────────────────────────────────────────────────
# URL publique de l'app (utilisée par Payload pour les liens emails, etc.)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ─── Vercel (preview deployments uniquement) ──────────────────────────────────
# Token Vercel Blob — créer dans Vercel > Storage > Blob > Manage > Tokens
# Nécessaire uniquement sur les environnements Vercel (preview)
# BLOB_READ_WRITE_TOKEN=

# DATABASE_URL sur Vercel pointe vers Neon Postgres (preview DB séparée de la prod)
# Configurer dans Vercel > Settings > Environment Variables > Preview
